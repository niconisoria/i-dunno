#!/usr/bin/env bash
set -euo pipefail

if [ -f Gemfile ]; then
  if grep -qE "gem ['\"]rspec" Gemfile; then
    echo RSpec
  elif grep -qE "gem ['\"]minitest" Gemfile; then
    echo Minitest
  else
    echo unknown
  fi
elif [ -f package.json ]; then
  node -e "
    const p = require('./package.json');
    const d = { ...p.devDependencies, ...p.dependencies };
    const f = ['jest','vitest','mocha','jasmine','ava'].find(k => k in d);
    console.log(f || 'unknown');
  " 2>/dev/null || echo unknown
elif [ -f pyproject.toml ] || [ -f pytest.ini ] || [ -f setup.cfg ]; then
  echo pytest
elif [ -f go.mod ]; then
  echo "Go test"
elif [ -f Cargo.toml ]; then
  echo "cargo test"
elif [ -f pom.xml ]; then
  echo JUnit
elif [ -f build.gradle ] || [ -f build.gradle.kts ]; then
  echo "JUnit 5"
elif [ -f composer.json ]; then
  grep -q pestphp composer.json && echo Pest || echo PHPUnit
elif [ -f mix.exs ]; then
  echo ExUnit
elif [ -f pubspec.yaml ]; then
  echo "Flutter test"
elif [ -f Package.swift ]; then
  echo XCTest
elif [ -f build.sbt ]; then
  echo ScalaTest
elif [ -f project.clj ] || [ -f deps.edn ]; then
  echo clojure.test
else
  echo unknown
fi
