#!/usr/bin/env bash
set -euo pipefail

# Usage: bin/advance-spec <spec-file-path> <new-status>
if [ $# -ne 2 ]; then
  echo "Usage: bin/advance-spec <spec-file-path> <new-status>" >&2
  exit 1
fi

FILE="$1"
STATUS="$2"

if [ ! -f "$FILE" ]; then
  echo "Error: file not found: $FILE" >&2
  exit 1
fi

if ! grep -q "^status:" "$FILE"; then
  echo "Error: no status: field in $FILE" >&2
  exit 1
fi

sed -i '' "s|^status: .*|status: $STATUS|" "$FILE"

if ! grep -q "^status: $STATUS" "$FILE"; then
  echo "Error: sed ran but status not updated in $FILE" >&2
  exit 1
fi

echo "ok: $FILE → $STATUS"
